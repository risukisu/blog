---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TerminalPrompt from '../components/TerminalPrompt.astro';
import LinkPreviewTooltip from '../components/LinkPreviewTooltip.astro';
import { SITE_TITLE } from '../consts';

// Read and parse CHANGELOG.md
const changelogRaw = await import('../../CHANGELOG.md?raw');
const lines = changelogRaw.default.split('\n');

// Parse into sections
const sections: { date: string; title: string; content: string[] }[] = [];
let current: { date: string; title: string; content: string[] } | null = null;

for (const line of lines) {
	if (line.startsWith('## ')) {
		if (current) sections.push(current);
		const match = line.match(/^## (\d{4}-\d{2}-\d{2}) — (.+)$/);
		current = {
			date: match ? match[1] : '',
			title: match ? match[2] : line.replace('## ', ''),
			content: []
		};
	} else if (current && !line.startsWith('# ')) {
		current.content.push(line);
	}
}
if (current) sections.push(current);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Changelog — ${SITE_TITLE}`} description="what changed and when" />
	</head>
	<body>
		<Header />
		<main>
			<TerminalPrompt command="git log --oneline" />

			{sections.map((section, i) => (
				<details class="changelog-entry" open={i < 3}>
					<summary>
						<span class="log-date">{section.date}</span>
						<span class="log-title">{section.title}</span>
					</summary>
					<div class="log-content" set:html={
						section.content.join('\n')
							.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="log-link">$1</a>')
							.replace(/`([^`]+)`/g, '<code>$1</code>')
							.replace(/^### (.+)$/gm, '<div class="log-heading">$1</div>')
							.replace(/^- \*\*(.+?)\*\* — (.+)$/gm, '<div class="log-item"><span class="log-bullet">✦︎</span><span class="log-text"><span class="log-key">$1</span> — $2</span></div>')
							.replace(/^- \*\*(.+?)\*\*(.*)$/gm, '<div class="log-item"><span class="log-bullet">✦︎</span><span class="log-text"><span class="log-key">$1</span>$2</span></div>')
							.replace(/^- (.+)$/gm, '<div class="log-item"><span class="log-bullet">✦︎</span><span class="log-text">$1</span></div>')
					} />
				</details>
			))}

			<div class="cursor-line">
				<span class="blinking-cursor">█</span>
			</div>
		</main>
		<Footer />
		<LinkPreviewTooltip />
	</body>
</html>

<style>
	.changelog-entry {
		border: 1px solid var(--border);
		margin-bottom: 0.5em;
	}
	.changelog-entry[open] {
		border-color: var(--border-bright, var(--border));
	}
	summary {
		cursor: pointer;
		padding: 0.6em 1em;
		display: flex;
		gap: 1em;
		align-items: baseline;
		list-style: none;
		transition: background 0.2s;
	}
	summary::-webkit-details-marker {
		display: none;
	}
	summary::before {
		content: '▸';
		color: var(--text-muted);
		font-size: 0.8em;
		transition: transform 0.2s;
	}
	details[open] > summary::before {
		content: '▾';
		color: var(--cyan);
	}
	summary:hover {
		background: var(--bg-surface);
	}
	.log-date {
		color: var(--green);
		font-size: 0.85em;
		white-space: nowrap;
	}
	.log-title {
		color: var(--text-bright);
		font-size: 0.9em;
	}
	.log-content {
		padding: 0 1em 1em 2.2em;
	}
	.log-content :global(.log-heading) {
		color: var(--amber);
		font-weight: 700;
		font-size: 0.9em;
		margin-top: 1em;
		margin-bottom: 0.4em;
		padding-bottom: 0.25em;
		border-bottom: 1px solid var(--amber);
		opacity: 0.9;
	}
	.log-content :global(.log-heading:first-child) {
		margin-top: 0.25em;
	}
	.log-content :global(.log-item) {
		font-size: 0.85em;
		padding: 0.5em 0;
		line-height: 1.6;
		border-bottom: 1px solid rgba(255, 255, 255, 0.04);
	}
	.log-content :global(.log-item:last-child) {
		border-bottom: none;
	}
	.log-content :global(.log-bullet) {
		margin-right: 0.5em;
		font-size: 0.6em;
		vertical-align: middle;
	}
	.log-content :global(.log-text) {
		color: var(--text-muted);
	}
	.log-content :global(.log-key) {
		color: var(--cyan);
		font-weight: 700;
	}
	.log-content :global(.log-link) {
		color: var(--cyan);
		text-decoration: none;
		transition: text-shadow 0.2s;
	}
	.log-content :global(.log-link:hover) {
		text-shadow: var(--glow-cyan);
	}
	.log-content :global(code) {
		color: var(--text-bright);
		font-size: 0.95em;
	}
	.cursor-line {
		margin-top: 2em;
	}
	.blinking-cursor {
		color: var(--green);
		animation: blink 1s step-end infinite;
	}
	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}
</style>
