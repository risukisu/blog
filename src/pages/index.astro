---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TerminalPrompt from '../components/TerminalPrompt.astro';
import AsciiBox from '../components/AsciiBox.astro';
import PostCard from '../components/PostCard.astro';
import LinkPreviewTooltip from '../components/LinkPreviewTooltip.astro';
import { SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description="risu's corner of the internet" />
	</head>
	<body>
		<Header />
		<main>
			<div class="ascii-hero">
				<pre class="mascot">{
`в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЈ вЈҖвЈҖвЈҖвЈҖв Җв Җ
в Җв Җв Җв Җв Җв ҖвЎҖвЎҖв ҖвўҖвЈ„в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЎӨв –в ӣв үв үв Җв Җв Җв үв івўӨ
в Җв Җв Җв Җв Җвў в һв үвЎҮвў в һвў№в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈӨвЎҙв Ӣв Җв Җв Җв Җв Җв Җв Җв Җв Җвўё
в Җв Җв Җв Җв ҖвЈјв Җв Җвў№в Үвўёв №вЎ„в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈ в һв үв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўЁ
в Җв Җв ҖвўҖвЎҙв ғв Ҳв Җв ҷв Җвўёв Җвў№вЎ„в Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЎңв Ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҳ
в Җв ҖвўҖвЎ”в үв ҖвЈҖвЈӨвЈӨвЎҖв »в Җв Җв івЈ„в Җв Җв Җв Җв Җв Җв Җв Җвў°в Ӣв Ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җвў в Һв Җв Җ
в Җв ҖвЈҫв Җв Җв һв ‘в ҝвўҝвЎҮв Җв Җв Җв Җв ҳв ўв Өв „вўҖвЈҖв Җв Җвў вЎҮв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЎ в –в үв Җв Җв Җв Җ
в Җв ҖвЎҹв Җв  в Ӯв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв үв ҷв ІвЈӨвЎҸв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЎҹв Җв Җв Җв Җв Җв Җ
в Җв ҖвЈ“вЈҫвЈ„вЈҖв Өв ҡвўҖв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҷвўҰв ҖвЎҮв Җв Җв Җв Җв Җв Җв Җвўёв ғв Җв Җв Җв Җв Җв Җ
в ҖвўёвЎҝвЈҝвЈҝвЎҸв ҷв ӣв җв Ӣв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҲвўівЎҖвў№в Җв Җв Җв Җв Җв ҖвЎҺв Җв Җв Җв Җв Җв Җв Җ
в Җв Җв №в ҝвЈҪвЈ—вЈ вЎһв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җвў»вЈҸв Җв Җв Җв Җв Җв Җвў§вЎҖв Җв Җв Җв Җв Җв Җ
в Җв Җв Җв Җв №вЎҖв ҷвўҰвЎҖв Җв Җв Җв ҖвўҖвЎҙв Өв Өв Өв „в Җв Җв Җв Җв Җв ҖвўёвЈҝв Җв Җв Җв Җв Җв ҖвўҫвЎ„в Җв Җв Җв Җв Җв Җ
в Җв Җв Җв Җв Җв ҳв ўвЈ„вЎҷв ҰвЈ„вЈ вЈҙв Һв Ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҝвЎҮв Җв Җв Җв ҖвЈҫвЎҸв Җв Җв Җв Җв Җв Җв Җ
в Җв Җв Җв Җв Җв Җв Җв Җв Ҳв үв үвЎҸвўёв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җвў вЎҹвЎҮв Җв Җв ҖвўҖвЈјв ҹв Җв Җв Җв Җв Җв Җв Җ
в “вўӨвЎҖв Җв Җв Җв Җв Җв Җв Җв Җвўёв ёвЎ„в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўёвўғвЎҮв Җв Җв Җв ёвЈ·в Җв Җв Җв Җв Җв Җв Җв Җ
в Җв Җв ҷв ҰвЈ„в Җв Җв Җв Җв Җв Җв ҖвўівЈҮв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЈҹвЎјв Җв Җв ҖвўҖвЎјв ғв Җв Җв Җв Җв Җв Җв Җв Җ
в Җв Җв Җв Җв Ҳв ҷв Ұвў„вЈҖвўҖвЈҖвЈҖвЎҖвў»вЈҶв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ӣв Җв Җв Җв ҖвЈёв Ӣв Җв Җв Җв Җв Җв Җв Җв Җв Җ
в Җв Җв Җв Җв Җв Җв Җв Җв Ҳв ҷвў·вЎҰв ҷв Ұвў„вЈ№вЈҹв ’в ҰвЈ вЎҖв Җв Җв Җв Җв Җв Җв ҖвўҖвЈҙв Ӣв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ
в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҳв ӣв “в ’в Ұвў„вЎүв Җв ҖвўүвЈ№вЎҖв Җв Җв Җв Җв ҖвўҖвЈ°вЎҹв Ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ
в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ҳв ҷв ҜвЎҖв Җв ұвЈӨвЈ„вЈҖвЈҖвЈӨв ¶в ӣв Ӣв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ
в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҳвў„в Ҳв үв Ғв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ
в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ‘в ўвЈ„в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ`
}</pre>
				<div class="hero-title">risu.pl</div>
				<div class="hero-subtitle">random memories & other things</div>
			</div>

			<TerminalPrompt command="whoami" />
			<p class="intro">
				A collection of my memory fragments of gaming, life, work, and everything between.
			</p>

			<TerminalPrompt command="cat recent_posts.md" />
			<AsciiBox title="recent posts">
				{posts.map((post) => (
					<PostCard
						title={post.data.title}
						date={post.data.pubDate}
						description={post.data.description}
						tags={post.data.tags}
						href={`/blog/${post.id}/`}
						variant="compact"
					/>
				))}
			</AsciiBox>

			<TerminalPrompt command="ls -la" />

			<AsciiBox title="links">
				<div class="link-list">
					<a href="/blog" class="link-item">
						<span class="link-glyph">[blog]</span>
						<span class="link-desc">random memories вҖ” gaming, life, work, and everything between</span>
					</a>
					<a href="https://github.com/risukisu" target="_blank" class="link-item">
						<span class="link-glyph">[github]</span>
						<span class="link-desc">code & projects</span>
					</a>
				</div>
			</AsciiBox>

			<div class="cursor-line">
				<span class="blinking-cursor">в–Ҳ</span>
			</div>
		</main>
		<Footer />
		<LinkPreviewTooltip />
	</body>
</html>

<style>
	.ascii-hero {
		text-align: center;
		margin-bottom: 1.5em;
	}
	.mascot {
		display: inline-block;
		font-size: 0.5em;
		line-height: 1.1;
		text-align: left;
		background: none !important;
		border: none !important;
		padding: 0 !important;
		margin: 0;
		color: var(--amber);
	}
	@media (max-width: 720px) {
		.mascot {
			font-size: 0.32em;
		}
	}
	.hero-title {
		color: var(--cyan);
		font-size: 1.4em;
		font-weight: 700;
		margin-top: 0.5em;
		text-shadow: var(--glow-cyan);
		letter-spacing: 0.1em;
	}
	.hero-subtitle {
		color: var(--text-muted);
		font-size: 0.85em;
		margin-top: 0.25em;
	}
	.intro {
		color: var(--text-bright);
		font-size: 1em;
		margin: 0.25em 0 2em;
	}
	.link-list {
		display: flex;
		flex-direction: column;
		gap: 0.75em;
	}
	.link-item {
		display: flex;
		gap: 0.75em;
		align-items: baseline;
		text-decoration: none;
		padding: 0.4em 0;
		transition: all 0.2s;
	}
	.link-item:hover {
		text-shadow: var(--glow-cyan);
	}
	.link-item:hover .link-desc {
		color: var(--text-bright);
	}
	.link-glyph {
		color: var(--cyan);
		font-weight: 700;
		white-space: nowrap;
	}
	.link-desc {
		color: var(--text-muted);
		font-size: 0.85em;
		transition: color 0.2s;
	}
	.cursor-line {
		margin-top: 2em;
	}
	.blinking-cursor {
		color: var(--green);
		animation: blink 1s step-end infinite;
	}
	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}
</style>
