---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TerminalPrompt from '../components/TerminalPrompt.astro';
import AsciiBox from '../components/AsciiBox.astro';
import LinkPreviewTooltip from '../components/LinkPreviewTooltip.astro';
import Terminal from '../components/Terminal.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Me — ${SITE_TITLE}`} description="about risu" />
	</head>
	<body>
		<Header />
		<main>
			<TerminalPrompt command="cat about.md" />

			<AsciiBox title="risu">
				<p>
					Hello ☕ — and welcome to my blog. 
				</p>
				<p>
					This is where my <mark>random memories</mark> live. Fragments from the terminal
					and beyond — gaming stories, life updates, work notes, and everything
					that doesn't fit anywhere else.
				</p>
				<p>
					Stay a while and read some. You too, <a href="https://risu.pl/blog/writing-for-no-one/" data-preview="Why do I even bother with writing a blog? Because I want to remember, and I want to safeguard a shard of the old internet." data-domain="risu.pl">should write more online</a>.
				</p>
			</AsciiBox>

			<AsciiBox title="links">
				<ul class="link-list">
					<li><a href="https://substack.com" target="_blank" class="featured">[&gt;] Substack</a></li>
					<li><a href="https://github.com/risukisu" target="_blank">[&gt;] GitHub</a></li>
				<li><a href="https://www.linkedin.com/in/andrzej-bialas/" target="_blank">[&gt;] LinkedIn</a></li>
				</ul>
			</AsciiBox>
			<Terminal />
		</main>
		<Footer />
		<LinkPreviewTooltip />
	</body>
</html>

<style>
	p {
		margin: 0.5em 0;
	}
	.link-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.link-list li {
		margin: 0.4em 0;
	}
	.link-list a {
		color: var(--text);
		text-decoration: none;
		transition: color 0.2s, text-shadow 0.2s;
	}
	.link-list a:hover {
		color: var(--cyan);
		text-shadow: var(--glow-cyan);
	}
	.link-list a.featured {
		color: var(--cyan);
		font-weight: 700;
		text-shadow: var(--glow-cyan);
	}
</style>
