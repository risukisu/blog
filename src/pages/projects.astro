---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TerminalPrompt from '../components/TerminalPrompt.astro';
import AsciiBox from '../components/AsciiBox.astro';
import LinkPreviewTooltip from '../components/LinkPreviewTooltip.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects — ${SITE_TITLE}`} description="things risu has built" />
	</head>
	<body>
		<Header />
		<main>
			<TerminalPrompt command="ls -la projects/" />

			<AsciiBox title="coming soon">
				<p class="placeholder">
					projects are loading... check back soon for things built with Claude Code and other tools.
				</p>
			</AsciiBox>

			<div class="cursor-line">
				<span class="blinking-cursor">█</span>
			</div>
		</main>
		<Footer />
		<LinkPreviewTooltip />

		<a href="/.well-known/dogs.txt" id="paw-btn" aria-label="dogs.txt">
			<svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
				<ellipse cx="5" cy="3.5" rx="1.6" ry="2" />
				<ellipse cx="11" cy="3.5" rx="1.6" ry="2" />
				<ellipse cx="2.5" cy="7" rx="1.4" ry="1.8" />
				<ellipse cx="13.5" cy="7" rx="1.4" ry="1.8" />
				<path d="M4.5 10.5c0-2 1.6-3.2 3.5-3.2s3.5 1.2 3.5 3.2c0 2.2-1.8 3.8-3.5 3.8s-3.5-1.6-3.5-3.8z" />
			</svg>
		</a>
	</body>
</html>

<style>
	.placeholder {
		color: var(--text-muted);
		margin: 0.5em 0;
	}
	#paw-btn {
		position: fixed;
		bottom: 1em;
		right: 1em;
		z-index: 9998;
		background: var(--bg-surface);
		border: 1px solid var(--border);
		color: var(--text-muted);
		opacity: 0.3;
		width: 36px;
		height: 36px;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		border-radius: 2px;
		text-decoration: none;
		transition: color 0.2s, border-color 0.2s, filter 0.2s, opacity 0.2s;
	}
	#paw-btn:hover {
		opacity: 1;
		color: var(--amber);
		border-color: var(--amber);
		filter: drop-shadow(0 0 6px rgba(255, 183, 0, 0.4));
	}
	.cursor-line {
		margin-top: 2em;
	}
	.blinking-cursor {
		color: var(--green);
		animation: blink 1s step-end infinite;
	}
	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}
</style>
