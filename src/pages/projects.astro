---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TerminalPrompt from '../components/TerminalPrompt.astro';
import AsciiBox from '../components/AsciiBox.astro';
import AsciiDivider from '../components/AsciiDivider.astro';
import LinkPreviewTooltip from '../components/LinkPreviewTooltip.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects — ${SITE_TITLE}`} description="open-source tools and experiments by risu" />
	</head>
	<body>
		<Header />
		<main>
			<TerminalPrompt command="ls -la projects/" />

			<AsciiBox title="vanilla-stats">
				<div class="project-card">
					<p class="project-desc">
						Single-file GA4 traffic analyzer — drop CSV exports, get an interactive dashboard. No install, no server, no dependencies.
					</p>
					<details class="project-features" open>
						<summary class="features-toggle">[features]</summary>
						<div class="features-list">
							<span class="feature-label">&gt; </span>YoY traffic comparison with 8-week moving average<br/>
							<span class="feature-label">&gt; </span>Google algorithm impact analysis (Core Updates + AI Overviews)<br/>
							<span class="feature-label">&gt; </span>Auto-generated key insights, winners &amp; losers<br/>
							<span class="feature-label">&gt; </span>Top 25 pages table with trend arrows and engagement data<br/>
							<span class="feature-label">&gt; </span>Works offline, works with file:// — just open and drop CSVs
						</div>
					</details>
					<div class="project-links">
						<a href="https://github.com/risukisu/vanilla-stats" target="_blank" class="project-link">
							<span class="link-glyph">[github]</span>
							<span class="link-text">risukisu/vanilla-stats</span>
						</a>
					</div>
				</div>
			</AsciiBox>

			<AsciiBox title="skillcraft">
				<div class="project-card">
					<p class="project-desc">
						Marketing skills marketplace for Claude Code — browse, collect, and share curated skills with collectible card aesthetics and community-driven rarity.
					</p>
					<details class="project-features" open>
						<summary class="features-toggle">[features]</summary>
						<div class="features-list">
							<span class="feature-label">&gt; </span>WoW-inspired rarity system (Common → Legendary) driven by community upvotes<br/>
							<span class="feature-label">&gt; </span>Warm Loot dark palette with prismatic animations and ANSI Shadow art<br/>
							<span class="feature-label">&gt; </span>Press Start 2P pixel font easter egg (persistent per user)<br/>
							<span class="feature-label">&gt; </span>Google + GitHub OAuth, skill submission with automated validation<br/>
							<span class="feature-label">&gt; </span>Gamification — points, 6 achievement types, download gating
						</div>
					</details>
					<div class="project-links">
						<a href="https://skillcraft.cloud" target="_blank" class="project-link">
							<span class="link-glyph">[demo]</span>
							<span class="link-text">skillcraft.cloud</span>
						</a>
						<a href="https://github.com/risukisu/Skills-trader" target="_blank" class="project-link">
							<span class="link-glyph">[github]</span>
							<span class="link-text">risukisu/Skills-trader</span>
						</a>
					</div>
				</div>
			</AsciiBox>

			<div class="cursor-line">
				<span class="blinking-cursor">█</span>
			</div>
		</main>
		<Footer />
		<LinkPreviewTooltip />

	</body>
</html>

<style>
	.project-card {
		display: flex;
		flex-direction: column;
		gap: 0.75em;
	}
	.project-desc {
		color: var(--text-bright);
		margin: 0;
		line-height: 1.5;
	}
	.project-features {
		color: var(--text-muted);
		font-size: 0.85em;
	}
	.features-toggle {
		cursor: pointer;
		color: var(--cyan);
		font-weight: 700;
		list-style: none;
		transition: text-shadow 0.2s;
	}
	.features-toggle::-webkit-details-marker {
		display: none;
	}
	.features-toggle::before {
		content: '▸ ';
		color: var(--cyan);
	}
	.project-features[open] .features-toggle::before {
		content: '▾ ';
	}
	.features-toggle:hover {
		text-shadow: var(--glow-cyan);
	}
	.features-list {
		margin-top: 0.5em;
		line-height: 1.8;
	}
	.feature-label {
		color: var(--green);
		font-weight: 700;
	}
	.project-tags {
		display: flex;
		gap: 0.5em;
		flex-wrap: wrap;
	}
	.tag {
		font-size: 0.8em;
		color: var(--text-muted);
	}
	.project-links {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
		margin-top: 0.25em;
	}
	.project-link {
		display: flex;
		gap: 0.75em;
		align-items: baseline;
		text-decoration: none;
		transition: all 0.2s;
	}
	.project-link:hover {
		text-shadow: var(--glow-cyan);
	}
	.project-link:hover .link-text {
		color: var(--text-bright);
	}
	.link-glyph {
		color: var(--cyan);
		font-weight: 700;
		font-size: 0.85em;
		white-space: nowrap;
	}
	.link-text {
		color: var(--text-muted);
		font-size: 0.85em;
		transition: color 0.2s;
	}
	.cursor-line {
		margin-top: 2em;
	}
	.blinking-cursor {
		color: var(--green);
		animation: blink 1s step-end infinite;
	}
	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}
</style>
